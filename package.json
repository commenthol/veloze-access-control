{
  "name": "@veloze/access-control",
  "version": "1.0.1",
  "description": "Middleware for access-control using @casl/ability",
  "homepage": "http://github.com/commenthol/veloze-access-control",
  "keywords": [
    "RBAC",
    "ABAC",
    "role-based access control",
    "attribute-based access control"
  ],
  "author": "commenthol",
  "sideEffects": false,
  "license": "MIT",
  "type": "module",
  "imports": {
    "#*": {
      "default": "./src/*"
    }
  },
  "exports": {
    "default": "./src/index.js",
    "types": "./types/index.d.ts"
  },
  "files": [
    "src",
    "types"
  ],
  "scripts": {
    "all": "npm-run-all lint test types",
    "test": "mocha '**/*.test.js'",
    "c8": "c8 -r text -r html npm test",
    "lint": "eslint",
    "types": "rimraf types; tsc"
  },
  "dependencies": {
    "veloze": "^1.5.2",
    "@casl/ability": "^6.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.3",
    "sinon": "^21.0.3",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
